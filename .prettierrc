{
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "endOfLine": "lf",
    "plugins": ["prettier-plugin-svelte"],
    "printWidth": 100,
    "semi": false,
    "tabWidth": 4,
    "trailingComma": "all",
    "overrides": [
        { "files": "*.json", "options": { "tabWidth": 2 } },
        { "files": "*.md", "options": { "tabWidth": 2 } },
        { "files": "*.svelte", "options": { "parser": "svelte" } },
        { "files": "*.yaml", "options": { "tabWidth": 2 } },
        { "files": "*.yml", "options": { "tabWidth": 2 } }
    ]
}
